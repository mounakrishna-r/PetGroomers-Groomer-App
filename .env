# PetGroomers Groomer App Environment Variables

# Backend API URL - Using local IP for Expo development
EXPO_PUBLIC_API_URL=http://192.168.1.2:8090

# Alternative: Use ngrok for external access
# EXPO_PUBLIC_API_URL=https://your-ngrok-url.ngrok-free.app

# For production deployment
# EXPO_PUBLIC_API_URL=https://your-production-api.com